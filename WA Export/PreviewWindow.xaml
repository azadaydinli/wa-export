<Window
    x:Class="WAExport.PreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Önizləmə">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid Padding="14,10" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Önizləmə" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Bağla" Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <!-- WebView2 -->
        <WebView2 Grid.Row="1" x:Name="WebView" VerticalAlignment="Stretch"/>

        <!-- WebView2 error panel -->
        <StackPanel x:Name="ErrorPanel" Grid.Row="1" Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Padding="32">
            <FontIcon Glyph="&#xE783;" FontSize="48"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="WebView2 Runtime tapılmadı"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Önizləmə üçün Microsoft Edge WebView2 Runtime lazımdır. Aşağıdakı düymə ilə quraşdırın."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
            <Button x:Name="DownloadButton" Content="WebView2 Runtime-ı endir və quraşdır"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Center"
                    Click="DownloadButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
